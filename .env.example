# Local development environment variables.
# Copy to .env and fill in values.

PORT=5000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret with the Next.js frontend
CODECOLLAB_INTERNAL_SECRET=

# Git worktree root (optional locally).
# Default when unset: backend/.data/worktrees/<project-id>  (gitignored)
# CODECOLLAB_REPOS_ROOT=.data/worktrees

# Production on EC2 + EBS example:
# CODECOLLAB_REPOS_ROOT=/var/lib/codecollab/worktrees
